def _readline() -> str:
    return _src()


def ss() -> str:
    return _readline().rstrip()


def ii() -> int:
    return int(ss())


def im():
    """'1 2' -> map; usage: a, b = im()"""
    return map(int, ss().split())


def li() -> list[int]:
    return list(map(int, ss().split()))


def lis() -> list[int]:
    """'123' -> [1, 2, 3] (digit string)"""
    return list(map(int, ss()))


def lc() -> list[str]:
    """'abc' -> ['a', 'b', 'c']"""
    return list(ss())


# Buffered output; flush=True for interactive
_out: list[str] = []
_real_print = print


def print(
    *args, sep: str = " ", end: str = "\n", file=None, flush: bool = False, **_
) -> None:
    if file is not None:
        _real_print(*args, sep=sep, end=end, file=file, flush=flush)
        return
    _out.append(sep.join(map(str, args)))
    _out.append(end)
    if flush:
        sys.stdout.write("".join(_out))
        _out.clear()
        sys.stdout.flush()


