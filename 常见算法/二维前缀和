def solve() -> None:
    h, w, k = im()
    s = [lis() for _ in range(h)]

    P = [[0] * (w + 1) for _ in range(h + 1)]
    for i in range(1, h + 1):
        s_row = s[i - 1]
        P_curr = P[i]
        P_prev = P[i - 1]
        for j in range(1, w + 1):
            P_curr[j] = s_row[j - 1] + P_prev[j] + P_curr[j - 1] - P_prev[j - 1]

    ans = 0

    for r_start in range(h):
        for r_end in range(r_start, h):
            cnt = {0: 1}
            for c in range(1, w + 1):
                prefix_sum = P[r_end + 1][c] - P[r_start][c]
                ans += cnt.get(prefix_sum - k, 0)
                cnt[prefix_sum] = cnt.get(prefix_sum, 0) + 1

    print(ans)


if __name__ == "__main__":
    solve()
    sys.stdout.write("".join(_out))
